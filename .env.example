# ─── Backend ──────────────────────────────────────────────
PORT=3400
NODE_ENV=development

# Nuvemshop App credentials (from Partners Portal)
CLIENT_ID="<YOUR_NUVEMSHOP_APP_ID>"
CLIENT_SECRET="<YOUR_NUVEMSHOP_CLIENT_SECRET>"

# Country for admin redirect after OAuth (br | ar)
STORE_COUNTRY=br

# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/launch_checklist"

# ─── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL="http://localhost:3400"
VITE_NEXO_CLIENT_ID="<YOUR_NUVEMSHOP_APP_ID>"
